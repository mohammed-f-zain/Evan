<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_enterprise_report_wizard_form" model="ir.ui.view">
        <field name="name">custom.enterprise.account.report.wizard.form</field>
        <field name="model">custom.enterprise.account.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Enterprise-like Financial Report" create="false" edit="false" delete="false">
                <header>
                    <button name="action_generate" string="Generate" type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <group col="4">
                        <field name="report_type"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>

                    <group col="3">
                        <field name="total_debit" readonly="1"/>
                        <field name="total_credit" readonly="1"/>
                        <field name="total_balance" readonly="1"/>
                    </group>

                    <field name="line_ids" nolabel="1" readonly="1">
                        <list create="false" delete="false" edit="false">
                            <field name="code"/>
                            <field name="name"/>
                            <field name="debit"/>
                            <field name="credit"/>
                            <field name="balance"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_enterprise_report_balance_sheet_ui" model="ir.actions.act_window">
        <field name="name">Balance Sheet</field>
        <field name="res_model">custom.enterprise.account.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_enterprise_report_wizard_form"/>
        <field name="target">current</field>
        <field name="context">{'default_report_type': 'balance_sheet'}</field>
    </record>

